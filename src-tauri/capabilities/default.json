{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Loom Desktop Client",
  "platforms": [
    "windows",
    "macOS",
    "linux"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:path:default",
    "allow-has-identity",
    "allow-generate-new-identity",
    "allow-get-my-token",
    "allow-add-contact-token",
    "allow-get-contacts",
    "allow-start-network",
    "allow-initiate-chat-handshake",
    "allow-send-message",
    "allow-get-messages"
  ]
}
